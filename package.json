{
  "name": "recomptrack",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "db:create": "wrangler d1 create bodyrecomposition-db",
    "db:migrate:local": "wrangler d1 migrations apply bodyrecomposition-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply bodyrecomposition-db --remote",
    "deploy": "npm run build && wrangler deploy",
    "dev:worker": "npm run build && wrangler dev --local",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260629.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "wrangler": "^4.105.0"
  }
}
